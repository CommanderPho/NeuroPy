{
  "include": [
    "neuropy"
  ],  
  "exclude":  [
    "**/__pycache__", "**/.classpath", "**/.factorypath", "**/.ipynb_checkpoints", "**/CVS", "**/.svn", "**/dist", "**/.virtual_documents", "**/.idea", "**/*.asv", "**/.git", "**/.spyproject", "**/.project", "**/node_modules", "**/.dvc", "**/build", "**/.settings", "**/.vscode", "**/.hg",
  ],
  "ignore":  [
    "src/oldstuff", "**/docs_sphinx", "**/.venv",
  ],
  "defineConstant": {
    "DEBUG": true
  },
  "reportMissingImports": true,
  "reportMissingTypeStubs": false,
  "reportOptionalMemberAccess": "none",
  "pythonVersion": "3.9",
}